{
	"name": "tailflow",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "tailflowdb",
			"database_name": "tailflow",
			"database_id": "9b3fdeea-7d8b-451c-8f57-1b4afc0cc37c"
		}
	],
	"r2_buckets": [
		{
			"binding": "tailflowr2",
			"bucket_name": "assets"
		}
	],
	"kv_namespaces": [
		{ "binding": "SESSION", "id": "SESSION" }
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
