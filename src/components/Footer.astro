---
const today = new Date();
---

<footer class="mt-16 border-t border-slate-200/80 bg-white/70 px-6 py-10 text-center backdrop-blur">
	<p class="text-sm text-slate-600">&copy; {today.getFullYear()} TailFlow. All rights reserved.</p>
	<div class="mt-4 flex justify-center gap-5">
		<a href="https://github.com" target="_blank" rel="noreferrer" class="text-sm font-medium text-slate-500 transition hover:text-cyan-700">GitHub</a>
		<a href="https://developers.cloudflare.com" target="_blank" rel="noreferrer" class="text-sm font-medium text-slate-500 transition hover:text-cyan-700">Cloudflare Docs</a>
		<a href="https://astro.build" target="_blank" rel="noreferrer" class="text-sm font-medium text-slate-500 transition hover:text-cyan-700">Astro</a>
	</div>
</footer>
