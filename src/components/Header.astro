---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="sticky top-0 z-20 border-b border-slate-200/80 bg-white/80 px-4 backdrop-blur md:px-8">
	<nav class="mx-auto flex w-full max-w-6xl items-center justify-between py-3">
		<h2 class="m-0">
			<a href="/" class="text-lg font-bold tracking-tight text-slate-900">{SITE_TITLE}</a>
		</h2>
		<div class="flex items-center gap-1">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About Us</HeaderLink>
		</div>
		<div class="hidden items-center gap-4 md:flex">
			<a href="https://github.com" target="_blank" rel="noreferrer" class="text-sm font-medium text-slate-500 transition hover:text-cyan-700">GitHub</a>
			<a href="https://developers.cloudflare.com" target="_blank" rel="noreferrer" class="text-sm font-medium text-slate-500 transition hover:text-cyan-700">Cloudflare</a>
		</div>
	</nav>
</header>
