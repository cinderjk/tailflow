---
interface Props {
	title: string;
	description: string;
	buttonText: string;
	buttonHref: string;
	id?: string;
}

const { title, description, buttonText, buttonHref, id } = Astro.props;
---

<section id={id} class="mt-12 rounded-2xl border border-cyan-200 bg-cyan-50 p-8 text-center">
	<h2 class="text-2xl font-semibold text-slate-900 md:text-3xl">{title}</h2>
	<p class="mt-3 text-slate-700">{description}</p>
	<a href={buttonHref} class="mt-6 inline-flex rounded-xl bg-slate-900 px-6 py-3 font-semibold text-white transition hover:bg-slate-700">
		{buttonText}
	</a>
</section>
