---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = 'About Us';
const pageDescription = 'Kenali tim dan visi TailFlow untuk membangun page builder Tailwind di atas Cloudflare Edge.';
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`${pageTitle} | ${SITE_TITLE}`} description={pageDescription} />
	</head>
	<body class="min-h-screen">
		<Header />
		<main class="mx-auto max-w-5xl px-6 py-12 md:px-10 md:py-16">
			<section class="rounded-3xl border border-cyan-200/70 bg-white/90 p-8 shadow-sm md:p-12">
				<p class="inline-flex rounded-full border border-cyan-200 bg-cyan-50 px-4 py-1 text-sm font-semibold text-cyan-800">
					About TailFlow
				</p>
				<h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">About Us</h1>
				<p class="mt-5 max-w-3xl text-lg leading-relaxed text-slate-700">
					TailFlow adalah inisiatif untuk menyederhanakan pembuatan landing page modern dengan pendekatan visual,
					tanpa meninggalkan fleksibilitas Tailwind CSS dan performa edge Cloudflare.
				</p>
			</section>

			<section class="mt-10 grid gap-5 md:grid-cols-3">
				<article class="rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm">
					<h2 class="text-lg font-semibold text-slate-900">Misi</h2>
					<p class="mt-3 text-slate-600">Membantu tim membangun page production-ready lebih cepat dari ide ke publish.</p>
				</article>
				<article class="rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm">
					<h2 class="text-lg font-semibold text-slate-900">Teknologi</h2>
					<p class="mt-3 text-slate-600">Dibangun dengan Astro, Tailwind, dan infrastruktur Cloudflare untuk latency rendah.</p>
				</article>
				<article class="rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm">
					<h2 class="text-lg font-semibold text-slate-900">Arah Produk</h2>
					<p class="mt-3 text-slate-600">Editor visual, workflow publishing, dan manajemen aset terintegrasi dalam satu platform.</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>
