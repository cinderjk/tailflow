---
import BaseHead from '../components/BaseHead.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import LandingCTA from '../components/LandingCTA.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const features = [
	{
		title: 'Visual Builder + Tailwind Utility',
		description:
			'Rakit halaman secara drag-and-drop sambil tetap menggunakan class Tailwind. Tim non-teknis bisa bergerak cepat tanpa menunggu sprint frontend.',
	},
	{
		title: 'Autosave Cepat di Cloudflare D1',
		description:
			'Setiap perubahan tersimpan sebagai JSON di D1. Workflow editing jadi aman, mudah rollback, dan siap untuk kolaborasi tim.',
	},
	{
		title: 'Output Ringan dan Siap Deploy',
		description:
			'Export ke HTML + CSS statis untuk performa tinggi. Cocok untuk campaign page, microsite, dan landing page bertrafik tinggi.',
	},
	{
		title: 'Asset Terpusat di R2',
		description:
			'Upload aset langsung ke R2 tanpa vendor tambahan. File lebih mudah dikelola dan delivery tetap dekat dengan user.',
	},
];
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="min-h-screen">
		<Header />
		<main class="mx-auto max-w-6xl px-6 py-10 md:px-10 md:py-14">

			<section class="relative overflow-hidden rounded-3xl border border-cyan-200/70 bg-white/85 p-8 shadow-xl shadow-cyan-100/40 backdrop-blur md:p-12">
				<div class="absolute -right-24 -top-24 h-64 w-64 rounded-full bg-cyan-300/30 blur-3xl"></div>
				<div class="absolute -bottom-24 -left-20 h-64 w-64 rounded-full bg-orange-200/40 blur-3xl"></div>
				<div class="relative">
					<p class="mb-4 inline-flex rounded-full border border-cyan-300 bg-cyan-50 px-4 py-1 text-sm font-semibold text-cyan-800">
						Keunggulan TailFlow
					</p>
					<h1 class="max-w-3xl text-4xl font-bold leading-tight text-slate-900 md:text-6xl">
						Mengapa TailFlow Lebih Unggul untuk Membangun Landing Page
					</h1>
					<p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-700">
						TailFlow menggabungkan kemudahan visual builder, kecepatan Tailwind, dan infrastruktur Cloudflare Edge
						untuk menghasilkan page yang cepat dibuat, cepat dimuat, dan mudah diskalakan.
					</p>
					<div class="mt-8 flex flex-wrap gap-3">
						<a href="#fitur" class="rounded-xl bg-cyan-700 px-6 py-3 font-semibold text-white transition hover:bg-cyan-800">
							Lihat Keunggulan
						</a>
						<a href="#stack" class="rounded-xl border border-slate-300 bg-white px-6 py-3 font-semibold text-slate-700 transition hover:border-cyan-400 hover:text-cyan-700">
							Lihat Teknologi
						</a>
					</div>
				</div>
			</section>

			<section id="fitur" class="mt-12 grid gap-5 md:grid-cols-2">
				{features.map((feature) => <FeatureCard title={feature.title} description={feature.description} />)}
			</section>

			<section id="stack" class="mt-12 rounded-3xl border border-slate-200 bg-slate-950 p-8 text-slate-100 md:p-10">
				<h2 class="text-3xl font-semibold">Fondasi Teknologi yang Andal</h2>
				<p class="mt-3 max-w-3xl text-slate-300">Setiap layer TailFlow dirancang untuk reliability, kecepatan deploy, dan biaya operasional yang efisien.</p>
				<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					<div class="rounded-xl border border-slate-800 bg-slate-900 p-4">Next.js Edge Runtime</div>
					<div class="rounded-xl border border-slate-800 bg-slate-900 p-4">Cloudflare Pages</div>
					<div class="rounded-xl border border-slate-800 bg-slate-900 p-4">Cloudflare D1 (SQLite)</div>
					<div class="rounded-xl border border-slate-800 bg-slate-900 p-4">Cloudflare R2</div>
					<div class="rounded-xl border border-slate-800 bg-slate-900 p-4">Drizzle ORM</div>
					<div class="rounded-xl border border-slate-800 bg-slate-900 p-4">Auth.js (NextAuth + D1 Adapter)</div>
				</div>
			</section>

			<LandingCTA
				id="mulai"
				title="Siap Rasakan Keunggulan TailFlow?"
				description="Mulai membangun landing page dengan workflow visual yang modern, performa edge, dan output siap produksi dalam hitungan menit."
				buttonText="Pelajari About Us"
				buttonHref="/about"
			/>
		</main>
		<Footer />
	</body>
</html>
