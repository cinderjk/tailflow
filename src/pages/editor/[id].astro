---
import 'grapesjs/dist/css/grapes.min.css';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE } from '../../consts';

export const prerender = false;

const projectId = Astro.params.id ?? 'demo';
const pageTitle = `Editor ${projectId}`;
const pageDescription = 'Editor visual TailFlow untuk menyusun landing page dengan GrapesJS dan Tailwind.';
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`${pageTitle} | ${SITE_TITLE}`} description={pageDescription} />
	</head>
	<body class="h-screen overflow-hidden bg-slate-100">
		<main class="flex h-screen min-h-0 flex-col">
			<header class="flex h-14 items-center justify-between border-b border-slate-200 bg-white px-4 md:px-6">
				<div class="flex items-center gap-3">
					<a href="/dashboard" class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50">
						Back
					</a>
					<p class="hidden text-sm text-slate-600 md:block">Editor: {projectId}</p>
				</div>
				<div class="flex items-center gap-3">
					<span id="save-status" class="hidden text-sm text-slate-500 md:inline">Belum ada perubahan tersimpan.</span>
					<button id="save-project" class="rounded-lg bg-cyan-700 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-cyan-800">
						Save
					</button>
				</div>
			</header>
			<section class="flex-1 min-h-0">
				<div id="gjs" class="h-full w-full" data-project-id={projectId}></div>
			</section>
		</main>

		<script>
			import grapesjs from 'grapesjs';
			import grapesjsTailwind from 'grapesjs-tailwind';

			const editorElement = document.getElementById('gjs');
			const saveButton = document.getElementById('save-project');
			const statusElement = document.getElementById('save-status');
			const projectId = editorElement?.dataset.projectId;

			if (editorElement instanceof HTMLElement && saveButton instanceof HTMLButtonElement && statusElement && projectId) {
				let isDirty = false;
				let isSaving = false;

				const editor = grapesjs.init({
					container: editorElement,
					height: '100%',
					fromElement: false,
					storageManager: false,
					plugins: [grapesjsTailwind],
					components: `
						<section class="bg-slate-950 px-8 py-20 text-white">
							<div class="mx-auto max-w-4xl text-center">
								<p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">TailFlow</p>
								<h1 class="mt-4 text-5xl font-bold">Bangun landing page lebih cepat di Cloudflare Edge.</h1>
								<p class="mt-6 text-lg text-slate-300">Mulai dari komponen visual, lanjutkan ke output HTML statis yang siap deploy.</p>
							</div>
						</section>
					`,
				});

				const loadExistingProject = async () => {
					try {
						const response = await fetch(`/api/projects/${projectId}`);

						if (!response.ok) {
							statusElement.textContent = 'Project baru. Mulai desain dari template awal.';
							isDirty = false;
							return;
						}

						const payload = await response.json();
						const projectPayload =
							payload && typeof payload === 'object' && 'project' in payload
								? payload.project
								: null;
						const dataJson =
							projectPayload && typeof projectPayload === 'object' && 'dataJson' in projectPayload
								? projectPayload.dataJson
								: null;
						const htmlContent =
							projectPayload && typeof projectPayload === 'object' && 'htmlContent' in projectPayload
								? projectPayload.htmlContent
								: null;

						if (dataJson && typeof editor.loadProjectData === 'function') {
							editor.loadProjectData(dataJson);
							statusElement.textContent = 'Project berhasil dimuat dari D1.';
							isDirty = false;
							return;
						}

						if (typeof htmlContent === 'string' && htmlContent.trim()) {
							editor.setComponents(htmlContent);
							statusElement.textContent = 'Konten HTML project berhasil dimuat.';
							isDirty = false;
							return;
						}

						statusElement.textContent = 'Project ditemukan tanpa data desain yang valid.';
					} catch {
						statusElement.textContent = 'Gagal memuat project dari server.';
					}
				};

				void loadExistingProject();

				const markDirty = () => {
					isDirty = true;
					statusElement.textContent = 'Perubahan belum disimpan.';
				};

				editor.on('update', markDirty);

				const saveProject = async (mode = 'manual') => {
					if (isSaving || (mode === 'auto' && !isDirty)) {
						return;
					}

					statusElement.textContent = mode === 'auto' ? 'Autosave berjalan...' : 'Menyimpan project...';
					isSaving = true;
					saveButton.disabled = true;

					try {
						const response = await fetch(`/api/projects/${projectId}`, {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json',
							},
							body: JSON.stringify({
								name: `Project ${projectId}`,
								userId: 'demo-user',
								dataJson: editor.getProjectData(),
								htmlContent: editor.getHtml(),
							}),
						});

						if (!response.ok) {
							throw new Error(`Save failed with status ${response.status}`);
						}

						isDirty = false;
						statusElement.textContent =
							mode === 'auto' ? 'Autosave sukses.' : 'Project berhasil disimpan ke D1.';
					} catch (error) {
						statusElement.textContent = error instanceof Error ? error.message : 'Gagal menyimpan project.';
					} finally {
						isSaving = false;
						saveButton.disabled = false;
					}
				};

				window.setInterval(() => {
					void saveProject('auto');
				}, 15000);

				saveButton.addEventListener('click', async () => {
					void saveProject('manual');
				});
			}
		</script>
	</body>
</html>