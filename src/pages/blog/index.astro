---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="min-h-screen">
		<Header />
		<main class="mx-auto max-w-6xl px-6 py-10 md:px-10 md:py-14">
			<section>
				<div class="mb-8 rounded-3xl border border-cyan-200/70 bg-white/90 p-8 shadow-sm">
					<h1 class="text-3xl font-bold text-slate-900 md:text-4xl">TailFlow Blog</h1>
					<p class="mt-3 text-slate-600">Insight seputar page building, edge architecture, dan update pengembangan produk.</p>
				</div>
				<ul class="grid list-none gap-6 p-0 md:grid-cols-2">
					{
						posts.map((post) => (
							<li>
								<a
									href={`/blog/${post.id}/`}
									class="group block overflow-hidden rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
								>
									<img width={720} height={360} src={post.data.heroImage} alt="" class="w-full rounded-xl" />
									<h4 class="mt-4 text-xl font-semibold text-slate-900 transition group-hover:text-cyan-700">{post.data.title}</h4>
									<p class="mt-2 text-sm text-slate-500">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
